        <mxCell id="BLqnNHzxtU8qZmyYr3ZF-4" value="Формирование списка продуктов" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="160" y="520" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="BLqnNHzxtU8qZmyYr3ZF-6" value="Оповещение&lt;div&gt;(пока емейл)&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
