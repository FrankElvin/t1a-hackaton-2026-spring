        <mxCell id="BLqnNHzxtU8qZmyYr3ZF-6" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="Оповещение&lt;div&gt;(пока емейл)&lt;/div&gt;" vertex="1">
