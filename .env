# =============================================================================
# Never Empty — Docker Compose values
# Copy/rename this file to .env and fill in all required values (marked with !)
# =============================================================================

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_DB_NAME=never_empty

# ── PostgreSQL (Keycloak storage) ─────────────────────────────────────────────
POSTGRES_DB=keycloak
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=changeme          # !

# ── Keycloak ──────────────────────────────────────────────────────────────────
# Port on the Docker host where Keycloak will be reachable.
# The browser and the backend both use http://localhost:<KEYCLOAK_PORT>.
KEYCLOAK_PORT=9090

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme    # !

# Realm and client must be created manually after first boot (see below).
KEYCLOAK_REALM=neverempty
KEYCLOAK_CLIENT_ID=household-ui

# ── Backend ───────────────────────────────────────────────────────────────────
# Host port the Spring Boot API will be exposed on.
BACKEND_PORT=8081

# ── Frontend ──────────────────────────────────────────────────────────────────
# Host port the React app (nginx) will be served on.
FRONTEND_PORT=3000

# ── OpenAI / LiteLLM ──────────────────────────────────────────────────────────
OPENAI_API_KEY=                     # !
OPENAI_BASE_URL=https://litellm.secondstack.t1a.io/v1
OPENAI_MODEL=gpt-4o-mini

# ── Google Cloud Service Account ──────────────────────────────────────────────
# Absolute or relative path to your service account JSON on the host machine.
# The file is bind-mounted read-only into the backend container.
GOOGLE_CREDENTIALS_FILE=./google-credentials.json   # !
GMAIL_IMPERSONATE_EMAIL=inbox@t1aclmllmagents.click  # !

# ── Barcode Lookup ────────────────────────────────────────────────────────────
BARCODE_LOOKUP_KEY=                 # !

# ── Notifications ─────────────────────────────────────────────────────────────
# How many days before depletion to send an alert.
NOTIFICATION_SOON_DAYS=3

# ── Dev / demo ────────────────────────────────────────────────────────────────
# Set to 'true' to skip Keycloak entirely in the browser (dev only).
# Requires a frontend rebuild when changed.
VITE_MOCK_AUTH=false

# =============================================================================
# KEYCLOAK FIRST-RUN SETUP
#
# After `docker compose up`, open http://localhost:9090 and log in with the
# admin credentials above. Then:
#
#   1. Create realm:  "neverempty"
#   2. Create client: clientId = "household-ui"
#                     Client type: OpenID Connect
#                     Valid redirect URIs: http://localhost:3000/*
#                     Web origins: http://localhost:3000
#                     Standard flow: enabled
#                     Direct access grants: disabled
# =============================================================================
